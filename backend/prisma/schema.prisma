// =====================================================================
// Prisma 数据模型定义
// AI驱动的家庭记账与财务规划Web应用
// 包含13个核心数据模型 + pgvector扩展 + 扩展预留字段
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== pgvector 扩展（为AI对话顾问RAG预留） ====================
// 需要在PostgreSQL中执行：CREATE EXTENSION IF NOT EXISTS vector;
// MVP阶段安装扩展，为后续向量检索预留

// ==================== 1. 用户模型 ====================
model User {
  id           String   @id @default(uuid())
  phone        String?  @unique @map("phone")    // 手机号（加密存储）
  email        String?  @unique @map("email")    // 邮箱（加密存储）
  passwordHash String?  @map("password_hash")    // 密码哈希
  wechatOpenId String?  @unique @map("wechat_open_id") // 微信OpenID
  nickname     String
  avatar       String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // 关联
  familiesOwned         Family[] @relation("FamilyOwner")
  ledgersOwned          Ledger[] @relation("LedgerOwner")
  familyMembers         FamilyMember[]
  transactions          Transaction[]
  importRecords         ImportRecord[]
  notifications         Notification[]
  classificationFeedbacks ClassificationFeedback[]
  reports               MonthlyReport[] @relation("ReportReadBy")
  refreshTokens         RefreshToken[]
  apiKeys               ApiKey[] // 智能体接入 API Key（MCP 鉴权，P0）
  accounts              Account[] @relation("AccountCreator") // 用户创建的账户（账户管理增量）
  recurringRules        RecurringRule[] // 用户创建的周期记账规则（二期）

  // ===== 债务/债券板块（T01）：垫付付款人 =====
  advanceReceivables    AdvanceReceivable[] @relation("AdvancePayer")

  @@map("users")
}

// ==================== API Key 模型（智能体接入 / MCP，P0） ====================
model ApiKey {
  id         String      @id @default(uuid())
  userId     String      @map("user_id")
  familyId   String      @map("family_id") // 冗余存储，便于快速隔离校验
  keyHash    String      @map("key_hash")   // scrypt(salt:hash) 拼接，永不明文落库
  scope      ApiKeyScope @default(READWRITE)
  name       String?                       // 用户备注，如「我的龙虾-只读」
  createdAt  DateTime    @default(now()) @map("created_at")
  revokedAt  DateTime?   @map("revoked_at") // 非空即吊销（硬吊销）
  lastUsedAt DateTime?   @map("last_used_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([familyId])
  @@map("api_keys")
}

// ==================== 2. 家庭模型 ====================
model Family {
  id               String   @id @default(uuid())
  name             String
  ownerId          String   @map("owner_id")
  avatar           String?
  inviteCode       String   @unique @map("invite_code")
  inviteCodeExpiry DateTime @map("invite_code_expiry")
  // 扩展预留字段
  baseCurrency     String   @default("CNY") @map("base_currency")
  settings         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // 关联
  owner      User           @relation("FamilyOwner", fields: [ownerId], references: [id])
  members    FamilyMember[]
  ledgers    Ledger[]
  categories Category[]
  budgets    Budget[]
  wishGoals     WishGoal[]
  reports       MonthlyReport[]
  importRecords ImportRecord[]
  accounts    Account[]          // 家庭下的账户（账户管理增量）
  recurringRules RecurringRule[] // 周期记账规则（二期）
  loans       Loan[]             // 按揭贷款（二期）

  // ===== 债务/债券板块（T01） =====
  bonds              Bond[]             // 债券（持有方 HELD）
  amortizationItems  AmortizationItem[] // 待摊/预付
  advanceReceivables AdvanceReceivable[] // 垫付应收

  @@map("families")
}

// ==================== 3. 家庭成员模型 ====================
model FamilyMember {
  id       String     @id @default(uuid())
  familyId String     @map("family_id")
  userId   String     @map("user_id")
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now()) @map("joined_at")

  // 关联
  family Family @relation(fields: [familyId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([familyId, userId])
  @@index([familyId])
  @@index([userId])
  @@map("family_members")
}

// ==================== 4. 账本模型 ====================
model Ledger {
  id        String     @id @default(uuid())
  familyId  String     @map("family_id")
  ownerId   String?    @map("owner_id") // 个人子账本的owner（共同账本为null）
  type      LedgerType @default(SHARED)
  name      String
  createdAt DateTime   @default(now()) @map("created_at")

  // 关联
  family       Family       @relation(fields: [familyId], references: [id])
  owner        User?        @relation("LedgerOwner", fields: [ownerId], references: [id])
  transactions  Transaction[]
  importRecords ImportRecord[]
  recurringRules RecurringRule[] // 周期记账规则（二期）
  loans       Loan[]             // 按揭贷款（二期）

  // ===== 债务/债券板块（T01） =====
  bonds              Bond[]             // 债券
  amortizationItems  AmortizationItem[] // 待摊/预付
  advanceReceivables AdvanceReceivable[] // 垫付应收

  @@index([familyId])
  @@map("ledgers")
}

// ==================== 5. 分类模型 ====================
model Category {
  id         String   @id @default(uuid())
  familyId   String   @map("family_id")
  parentId   String?  @map("parent_id")
  name       String
  icon       String
  // 颜色可空：null 表示「继承父级(一级)颜色」，非空表示自身覆盖色
  color      String?
  sortOrder  Int      @default(0) @map("sort_order")
  isSystem   Boolean  @default(false) @map("is_system")
  // 扩展预留字段
  rules      Json?
  createdAt  DateTime @default(now()) @map("created_at")

  // 关联
  family       Family    @relation(fields: [familyId], references: [id])
  parent       Category? @relation("CategoryParent", fields: [parentId], references: [id])
  children     Category[] @relation("CategoryParent")
  transactions Transaction[]
  budgets      Budget[]
  recurringRules RecurringRule[] // 周期记账规则（二期）

  @@index([familyId])
  @@index([parentId])
  @@map("categories")
}

// ==================== 6. 交易模型（核心） ====================
model Transaction {
  id             String             @id @default(uuid())
  ledgerId       String             @map("ledger_id")
  userId         String             @map("user_id")
  categoryId     String?            @map("category_id")
  type           TransactionType
  amount         Decimal            @db.Decimal(12, 2) // 金额（单位元）
  date           DateTime
  merchant       String?
  note           String?
  source         TransactionSource  @default(MANUAL)
  importRecordId String?            @map("import_record_id")
  aiConfidence   Float?             @map("ai_confidence") // 0-1
  aiCorrected    Boolean            @default(false) @map("ai_corrected")
  isLargeExpense Boolean            @default(false) @map("is_large_expense")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  // ===== MVP阶段扩展预留字段（重要） =====
  currency       String             @default("CNY") // 多币种预留
  metadata       Json?              // 扩展属性预留（投资关联ID、外币原始金额等）
  tags           String[]           @default([])    // 自定义标签预留（多维分析）

  // 关联
  ledger       Ledger               @relation(fields: [ledgerId], references: [id])
  user         User                 @relation(fields: [userId], references: [id])
  category     Category?            @relation(fields: [categoryId], references: [id])
  importRecord ImportRecord?        @relation(fields: [importRecordId], references: [id])
  feedbacks    ClassificationFeedback[]

  // ===== 账户关联（账户管理增量，accountId 可空：历史交易允许为空） =====
  accountId    String?              @map("account_id")
  account      Account?             @relation("AccountTransactions", fields: [accountId], references: [id])

  // ===== 二期扩展列（退款/报销/分期，均可空/有默认值，向后兼容） =====
  installmentGroupId  String?  @map("installment_group_id") // 同组分期标识（独立 N 笔交易分组）
  installmentSeq      Int?     @map("installment_seq")       // 第几期（1..N）
  installmentTotal    Int?     @map("installment_total")     // 总期数
  refundOfId          String?  @map("refund_of_id")          // 指向原支出（退款反向 INCOME 交易）
  refundedAmount      Decimal? @default(0) @db.Decimal(12, 2) @map("refunded_amount")
  refundStatus        RefundStatus @default(NONE) @map("refund_status")
  reimbursementOfId   String?  @map("reimbursement_of_id")   // 指向原支出（报销收入交易）
  reimbursementStatus ReimburseStatus @default(NONE) @map("reimbursement_status")

  // ===== 债务/债券板块扩展（垫付/待摊，均可空、向后兼容） =====
  advanceOfId         String?  @map("advance_of_id")          // 指向 AdvanceReceivable（垫付收回 INCOME 交易，复用 reimbursementOfId 模式）
  amortizationItemId  String?  @map("amortization_item_id")    // 指向 AmortizationItem（摊销 EXPENSE 标记，Net Expense 中排除）

  // 垫付源交易反向关联（AdvanceReceivable.sourceTx 指向本交易）
  advanceSourceTxes   AdvanceReceivable[] @relation("AdvanceSourceTx")

  @@index([ledgerId, date(sort: Desc)])
  @@index([categoryId, date(sort: Desc)])
  @@index([userId, date(sort: Desc)])
  @@index([importRecordId])
  @@index([accountId])
  @@index([installmentGroupId])
  @@index([refundOfId])
  @@index([reimbursementOfId])
  @@index([advanceOfId])
  @@index([amortizationItemId])
  @@map("transactions")
}

// ==================== 周期记账规则模型（二期） ====================
model RecurringRule {
  id         String   @id @default(uuid())
  familyId   String   @map("family_id")
  ledgerId   String   @map("ledger_id")
  userId     String   @map("user_id")
  categoryId String?  @map("category_id")
  accountId  String?  @map("account_id")
  type       TransactionType
  amount     Decimal  @db.Decimal(12, 2)
  merchant   String?
  note       String?
  frequency  Frequency
  interval   Int      @default(1)
  weekday    Int?     @map("weekday")     // 1-7（WEEKLY）
  monthDay   Int?     @map("month_day")   // 1-31（MONTHLY）
  startDate  DateTime @map("start_date")
  endDate    DateTime? @map("end_date")
  nextRunAt  DateTime @map("next_run_at") // 生成游标
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  family   Family   @relation(fields: [familyId], references: [id])
  ledger   Ledger   @relation(fields: [ledgerId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  @@index([familyId])
  @@index([nextRunAt])
  @@map("recurring_rules")
}

// ==================== 按揭贷款模型（二期） ====================
model Loan {
  id         String    @id @default(uuid())
  familyId   String    @map("family_id")
  ledgerId   String    @map("ledger_id")
  accountId  String?   @map("account_id")
  name       String
  principal  Decimal   @db.Decimal(14, 2)
  annualRate Decimal   @db.Decimal(6, 4) @map("annual_rate")
  termMonths Int       @map("term_months")
  method     LoanMethod
  startDate  DateTime  @map("start_date")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")

  family    Family        @relation(fields: [familyId], references: [id])
  ledger    Ledger        @relation(fields: [ledgerId], references: [id])
  schedules LoanSchedule[]

  @@index([familyId])
  @@map("loans")
}

model LoanSchedule {
  id                String   @id @default(uuid())
  loanId            String   @map("loan_id")
  seq               Int
  dueDate           DateTime @map("due_date")
  payment           Decimal  @db.Decimal(12, 2)
  principalPart     Decimal  @db.Decimal(12, 2) @map("principal_part")
  interestPart      Decimal  @db.Decimal(12, 2) @map("interest_part")
  remainingPrincipal Decimal @db.Decimal(14, 2) @map("remaining_principal")
  generatedTxId     String?  @map("generated_tx_id") // 关联已生成的本金还款交易
  generatedInterestTxId String? @map("generated_interest_tx_id") // 关联已生成的利息支出交易（决策②双笔）
  status            String   @default("pending")      // pending/paid/skipped

  loan Loan @relation(fields: [loanId], references: [id])

  @@index([loanId])
  @@index([generatedInterestTxId])
  @@map("loan_schedules")
}

// ==================== 账户模型（账户管理增量） ====================
model Account {
  id              String      @id @default(uuid())
  familyId        String      @map("family_id")                 // 所属家庭
  ledgerId        String?     @map("ledger_id")                 // 归属账本，共同账户可为null（决策#4）
  userId          String      @map("user_id")                   // 创建者
  type            AccountType
  name            String
  balance         Decimal     @db.Decimal(12, 2)                // 储蓄/投资/现金/钱包/虚拟=余额；信用卡=当前欠款
  institution     String?                                        // 机构（储蓄卡/信用卡）
  lastFourDigits  String?     @map("last_four_digits")          // 卡号后4位
  creditLimit     Decimal?    @db.Decimal(12, 2) @map("credit_limit")    // 信用卡授信额度
  billingDay      Int?        @map("billing_day")               // 1-28
  paymentDueDay   Int?        @map("payment_due_day")           // 1-28
  availableCredit Decimal?    @db.Decimal(12, 2) @map("available_credit") // 信用卡可用额度=授信-欠款（后端计算存储）
  platform        String?                                        // 投资/钱包平台
  purpose         String?                                        // 虚拟账户用途
  currency        String      @default("CNY")
  isActive        Boolean     @default(true)  @map("is_active") // 停用不删除（决策#3）
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt       @map("updated_at")

  // 关联
  family       Family       @relation(fields: [familyId], references: [id])
  creator      User         @relation("AccountCreator", fields: [userId], references: [id])
  transactions Transaction[] @relation("AccountTransactions")

  @@index([familyId])
  @@index([ledgerId])
  @@map("accounts")
}

// ==================== 7. 账单导入记录模型 ====================
model ImportRecord {
  id            String         @id @default(uuid())
  userId        String         @map("user_id")
  familyId      String         @map("family_id")
  ledgerId      String         @map("ledger_id")
  platform      ImportPlatform
  fileName      String         @map("file_name")
  fileUrl       String         @map("file_url")
  totalCount    Int            @default(0) @map("total_count")
  successCount  Int            @default(0) @map("success_count")
  failedCount   Int            @default(0) @map("failed_count")
  aiAccuracy    Float?         @map("ai_accuracy")
  status        ImportStatus   @default(PENDING)
  errorMessage  String?        @map("error_message")
  createdAt     DateTime       @default(now()) @map("created_at")
  confirmedAt   DateTime?      @map("confirmed_at")

  // 关联
  user         User           @relation(fields: [userId], references: [id])
  family       Family         @relation(fields: [familyId], references: [id])
  ledger       Ledger         @relation(fields: [ledgerId], references: [id])
  transactions Transaction[]

  @@index([userId])
  @@index([familyId])
  @@map("import_records")
}

// ==================== 8. 预算模型 ====================
model Budget {
  id         String   @id @default(uuid())
  familyId   String   @map("family_id")
  categoryId String?  @map("category_id") // null表示总预算
  amount     Decimal  @db.Decimal(12, 2)
  period     String   @default("monthly") // 预算周期（MVP仅月度）
  year       Int
  month      Int      // 1-12
  wishGoalId String?  @map("wish_goal_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // 关联
  family    Family    @relation(fields: [familyId], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])
  wishGoal  WishGoal? @relation(fields: [wishGoalId], references: [id])

  @@unique([familyId, categoryId, year, month])
  @@index([familyId, year, month])
  @@map("budgets")
}

// ==================== 9. 心愿目标模型 ====================
model WishGoal {
  id            String   @id @default(uuid())
  familyId      String   @map("family_id")
  name          String
  targetAmount  Decimal  @db.Decimal(12, 2) @map("target_amount")
  currentAmount Decimal  @db.Decimal(12, 2) @default(0) @map("current_amount")
  targetDate    DateTime? @map("target_date")
  icon          String
  color         String
  isCompleted   Boolean  @default(false) @map("is_completed")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // 关联
  family  Family    @relation(fields: [familyId], references: [id])
  budgets Budget[]

  @@index([familyId])
  @@map("wish_goals")
}

// ==================== 10. 月度报告模型 ====================
model MonthlyReport {
  id                     String   @id @default(uuid())
  familyId               String   @map("family_id")
  year                   Int
  month                  Int      // 1-12
  totalIncome            Decimal  @db.Decimal(14, 2) @map("total_income")
  totalExpense           Decimal  @db.Decimal(14, 2) @map("total_expense")
  balance                Decimal  @db.Decimal(14, 2)
  previousMonthBalance   Decimal? @db.Decimal(14, 2) @map("previous_month_balance")
  // JSONB字段：灵活存储聚合数据
  categoryBreakdown      Json     @map("category_breakdown")
  anomalies              Json
  advice                 Json
  benchmarkComparison    Json?    @map("benchmark_comparison")
  generatedAt            DateTime @default(now()) @map("generated_at")

  // 关联
  family  Family  @relation(fields: [familyId], references: [id])
  readBy  User[]  @relation("ReportReadBy")

  @@unique([familyId, year, month])
  @@index([familyId])
  @@map("monthly_reports")
}

// ==================== 11. 通知模型 ====================
model Notification {
  id        String            @id @default(uuid())
  userId    String            @map("user_id")
  type      NotificationType
  title     String
  content   String
  data      Json              // 附加数据（如跳转参数）
  isRead    Boolean           @default(false) @map("is_read")
  createdAt DateTime          @default(now()) @map("created_at")

  // 关联
  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

// ==================== 12. AI分类反馈模型 ====================
model ClassificationFeedback {
  id                  String   @id @default(uuid())
  transactionId       String   @map("transaction_id")
  userId              String   @map("user_id")
  originalCategoryId  String?  @map("original_category_id")
  correctedCategoryId String   @map("corrected_category_id")
  merchant            String
  amount              Decimal  @db.Decimal(12, 2)
  createdAt           DateTime @default(now()) @map("created_at")

  // 关联
  transaction Transaction @relation(fields: [transactionId], references: [id])
  user        User         @relation(fields: [userId], references: [id])

  @@index([transactionId])
  @@index([userId])
  @@map("classification_feedbacks")
}

// ==================== 13. 用户Token管理模型（JWT刷新令牌） ====================
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  // 关联
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ==================== 枚举定义 ====================

enum MemberRole {
  OWNER    // 创建者（最高权限）
  ADMIN    // 管理员（记账+管理成员）
  MEMBER   // 普通成员（记账+查看）
  VIEWER   // 只读成员（仅查看）
}

enum LedgerType {
  SHARED     // 家庭共同账本
  PERSONAL   // 个人子账本
}

enum TransactionType {
  INCOME     // 收入
  EXPENSE    // 支出
  TRANSFER   // 内部转账（预留）
}

enum TransactionSource {
  MANUAL        // 手动记账
  QUICK_RECORD  // Ctrl+K快捷记账
  IMPORT        // 账单导入
  VOICE         // 语音记账（P2预留）
  AGENT         // 智能体（QClaw / MCP）记账
}

// ==================== API Key 作用域枚举（智能体接入） ====================
enum ApiKeyScope {
  READONLY    // 只读：仅允许 get* 类工具
  READWRITE   // 读写：允许记账等写类工具
}

enum ImportPlatform {
  ALIPAY  // 支付宝
  WECHAT  // 微信
  CMB     // 招商银行
  ICBC    // 工商银行
  CCB     // 建设银行
}

enum ImportStatus {
  PENDING    // 等待解析
  PARSING    // 解析中
  PREVIEW    // 待确认预览
  CONFIRMED  // 已确认导入
  FAILED     // 解析失败
}

// ==================== 账户类型枚举（账户管理增量） ====================
enum AccountType {
  DEBIT       // 储蓄卡
  CREDIT      // 信用卡
  INVESTMENT  // 投资
  CASH        // 现金
  E_WALLET    // 钱包（支付宝/微信）
  VIRTUAL     // 虚拟
}

enum NotificationType {
  BUDGET_WARNING     // 预算预警
  BUDGET_EXCEEDED    // 预算超支
  BUDGET_SUCCESS     // 预算达成
  LARGE_EXPENSE      // 大额支出
  MONTHLY_REPORT     // 月报生成
  FAMILY_MEMBER_JOIN // 成员加入
  IMPORT_COMPLETE    // 导入完成
}

// ==================== 二期扩展枚举 ====================

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum LoanMethod {
  EQUAL_INSTALLMENT // 等额本息
  EQUAL_PRINCIPAL   // 等额本金
}

enum RefundStatus {
  NONE
  PARTIAL
  FULL
}

enum ReimburseStatus {
  NONE
  PENDING
  REIMBURSED
}

// ==================== 债务/债券板块枚举（T01） ====================

enum CouponFrequency {
  MONTHLY   // 按月付息
  QUARTERLY // 按季付息
  SEMI      // 按半年付息
  ANNUAL    // 按年付息
}

enum AmortizationType {
  PREPAID  // 预付（先付后摊）
  DEFERRED // 待摊（先发生后摊）
}

enum PeriodType {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum DebtorType {
  PERSON   // 个人
  COMPANY  // 公司
  FAMILY   // 家庭
}

enum AdvanceStatus {
  PENDING    // 待收回
  PARTIAL    // 部分收回
  RECOVERED  // 已全部收回
  CANCELLED  // 已取消
}

// ==================== 债券模型（债务/债券板块 T01） ====================
model Bond {
  id           String         @id @default(uuid())
  familyId     String         @map("family_id")
  ledgerId     String         @map("ledger_id")
  accountId    String?        @map("account_id")
  name         String
  faceValue    Decimal        @db.Decimal(14, 2) @map("face_value")
  annualRate   Decimal        @db.Decimal(6, 4) @map("annual_rate")
  termMonths   Int            @map("term_months")
  method       LoanMethod     @default(EQUAL_INSTALLMENT) // 仅占位，债券票息固定
  couponFrequency CouponFrequency @map("coupon_frequency")
  startDate    DateTime       @map("start_date")
  categoryId   String?        @map("category_id")
  isActive     Boolean        @default(true) @map("is_active")
  createdAt    DateTime       @default(now()) @map("created_at")

  family    Family           @relation(fields: [familyId], references: [id])
  ledger    Ledger           @relation(fields: [ledgerId], references: [id])
  schedules BondSchedule[]

  @@index([familyId])
  @@map("bonds")
}

model BondSchedule {
  id                  String   @id @default(uuid())
  bondId              String   @map("bond_id")
  seq                 Int
  dueDate             DateTime @map("due_date")
  coupon              Decimal  @db.Decimal(14, 2) // 每期票息（持有方 INCOME）
  principalReturn     Decimal  @db.Decimal(14, 2) @map("principal_return") // 仅末期=面值，其余 0
  remainingPrincipal  Decimal  @db.Decimal(14, 2) @map("remaining_principal")
  generatedTxId       String?  @map("generated_tx_id") // 票息 INCOME 交易（coupon）
  generatedInterestTxId String? @map("generated_interest_tx_id") // 末期本金返还 INCOME 交易（principalReturn）
  status              String   @default("pending") // pending/paid/skipped

  bond Bond @relation(fields: [bondId], references: [id])

  @@index([bondId])
  @@map("bond_schedules")
}

// ==================== 待摊/预付模型（债务/债券板块 T01） ====================
model AmortizationItem {
  id              String          @id @default(uuid())
  familyId        String          @map("family_id")
  ledgerId        String          @map("ledger_id")
  accountId       String?         @map("account_id")
  name            String
  totalAmount     Decimal         @db.Decimal(14, 2) @map("total_amount")
  amortizedAmount Decimal         @db.Decimal(14, 2) @default(0) @map("amortized_amount")
  remainingAmount Decimal         @db.Decimal(14, 2) @map("remaining_amount")
  startDate       DateTime        @map("start_date")
  periodMonths    Int             @map("period_months")
  periodType      PeriodType      @default(MONTHLY) @map("period_type")
  type            AmortizationType // PREPAID 预付 / DEFERRED 待摊
  categoryId      String?         @map("category_id")
  sourceTxId      String?         @map("source_tx_id") // 初始入账 EXPENSE 交易
  note            String?
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")

  family    Family              @relation(fields: [familyId], references: [id])
  ledger    Ledger              @relation(fields: [ledgerId], references: [id])
  schedules AmortizationSchedule[]

  @@index([familyId])
  @@map("amortization_items")
}

model AmortizationSchedule {
  id            String   @id @default(uuid())
  itemId        String   @map("item_id")
  seq           Int
  dueDate       DateTime @map("due_date")
  amount        Decimal  @db.Decimal(14, 2) // 每期摊销额（= totalAmount / periodMonths，末期校正）
  generatedTxId String?  @map("generated_tx_id") // 摊销 EXPENSE 交易
  status        String   @default("pending") // pending/posted/skipped

  item AmortizationItem @relation(fields: [itemId], references: [id])

  @@index([itemId])
  @@map("amortization_schedules")
}

// ==================== 垫付应收模型（债务/债券板块 T01） ====================
model AdvanceReceivable {
  id           String       @id @default(uuid())
  familyId     String       @map("family_id")
  ledgerId     String       @map("ledger_id")
  accountId    String?      @map("account_id")
  payerId      String       @map("payer_id") // 垫付人（家庭成员）
  debtorName   String       @map("debtor_name")
  debtorType   DebtorType   @map("debtor_type")
  sourceTxId   String       @map("source_tx_id") // 源支出交易
  amount       Decimal      @db.Decimal(14, 2)
  repaidAmount Decimal      @db.Decimal(14, 2) @default(0) @map("repaid_amount")
  remainingAmount Decimal   @db.Decimal(14, 2) @map("remaining_amount")
  dueDate      DateTime?    @map("due_date")
  status       AdvanceStatus @default(PENDING) @map("status")
  note         String?
  createdAt    DateTime     @default(now()) @map("created_at")

  family Family @relation(fields: [familyId], references: [id])
  ledger Ledger @relation(fields: [ledgerId], references: [id])
  payer  User   @relation("AdvancePayer", fields: [payerId], references: [id])
  sourceTx Transaction? @relation("AdvanceSourceTx", fields: [sourceTxId], references: [id])

  @@index([familyId])
  @@index([ledgerId])
  @@index([payerId])
  @@index([status])
  @@map("advance_receivables")
}
