    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "csv-parse": "^5.5.6",
    "dayjs": "^1.11.12",
    "helmet": "^7.1.0",
    "iconv-lite": "^0.6.3",
    "ioredis": "^5.4.1",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.7",
    "nest-winston": "^1.9.7",
    "nodemailer": "^6.9.14",
    "passport": "^0.7.0",
    "passport-http-bearer": "^1.0.1",
    "passport-jwt": "^4.0.1",
