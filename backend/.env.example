# ========== 后端环境变量（16项） ==========

# 应用环境
NODE_ENV=development

# 服务端口
PORT=3001

# 数据库
DATABASE_URL="postgresql://family_finance:family_finance_pwd@localhost:5432/family_finance?schema=public"
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=family_finance
DATABASE_USER=family_finance
DATABASE_PASSWORD=family_finance_pwd

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT认证
JWT_ACCESS_SECRET=your-access-token-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS白名单
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 阿里云OSS
OSS_REGION=oss-cn-shanghai
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_BUCKET=family-finance-files

# 通义千问LLM
LLM_API_KEY=your-qianwen-api-key
LLM_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigeneration/text-generation/generation
LLM_MODEL=qwen-turbo

# 微信扫码登录
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# Web Push
WEB_PUSH_PUBLIC_KEY=your-web-push-public-key
WEB_PUSH_PRIVATE_KEY=your-web-push-private-key

# 邮件服务
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@family-finance.com

# 加密密钥（AES-256，32字符）
CRYPTO_SECRET_KEY=your-32-char-secret-key-here
