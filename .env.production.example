# ============================================================
# 家庭财务管理系统 - 生产环境配置模板
# ============================================================
# 使用方法：
#   1. 复制本文件为 .env：  cp .env.production.example .env
#   2. 修改下方所有 !!! 标记的项为你的真实配置
#   3. 启动：  docker-compose up -d --build
# ============================================================

# ========== 数据库 ==========
DB_NAME=family_finance
DB_USER=family_finance
# !!! 修改为强密码（至少16位随机字符串）
DB_PASSWORD=ChangeMe_To_Strong_Password_2026!!!

# ========== Redis ==========
# 留空则不启用密码
REDIS_PASSWORD=

# ========== JWT认证 ==========
# !!! 修改为随机字符串（建议32位以上）
JWT_ACCESS_SECRET=ChangeMe_Access_Secret_Random_String!!!
JWT_REFRESH_SECRET=ChangeMe_Refresh_Secret_Random_String!!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ========== CORS白名单 ==========
# !!! 改为你的服务器IP或域名，多个用逗号分隔
# 例如：http://123.45.67.89,https://finance.mydomain.com
CORS_ORIGINS=http://localhost,http://localhost:5173

# ========== 通义千问LLM ==========
# !!! 填入你的阿里云DashScope API Key
# 获取地址：https://dashscope.console.aliyun.com/apiKey
LLM_API_KEY=your-qianwen-api-key-here
LLM_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigeneration/text-generation/generation
LLM_MODEL=qwen-turbo

# ========== 阿里云OSS（文件存储） ==========
# !!! 填入你的阿里云OSS配置，或在MVP阶段留空（文件存本地）
OSS_REGION=oss-cn-shanghai
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=

# ========== 微信扫码登录（可选） ==========
# MVP阶段可留空，不影响核心功能
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ========== Web Push推送通知（可选） ==========
# MVP阶段可留空
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=

# ========== 邮件服务（可选） ==========
# MVP阶段可留空
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ========== 加密密钥 ==========
# !!! 修改为32位随机字符串（用于AES-256加密）
CRYPTO_SECRET_KEY=ChangeMe_32_Char_Secret_Key!!!

# ========== 前端配置 ==========
# !!! 如果使用域名+HTTPS，改为 https://yourdomain.com/api
# 如果通过Nginx反代（推荐），改为 /api 即可
VITE_API_BASE_URL=/api
# !!! WebSocket地址，留空则自动使用当前页面host
VITE_WS_URL=
VITE_APP_NAME=家庭财务管家
